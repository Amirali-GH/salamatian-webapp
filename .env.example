# ─── Application ───────────────────────────────────────────
APP_NAME=Salamatian
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string
BASE_URL=http://localhost:8000

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://salamatian:salamatian@postgres:5432/salamatian

# ─── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── JWT ───────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# ─── Storage ───────────────────────────────────────────────
STORAGE_ROOT=/app/storage/uploads
EXCEL_INBOX_DIR=/app/storage/uploads/excel/inbox
MAX_IMAGE_SIZE_MB=5
MAX_LEAD_IMAGES=10

# ─── Rate limiting ─────────────────────────────────────────
PUBLIC_LEAD_RATE_PER_HOUR=10

# ─── Admin bootstrap ───────────────────────────────────────
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@salamatian.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!123

# ─── Optional notification channels ────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@salamatian.local
