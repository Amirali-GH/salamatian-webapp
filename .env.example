# ─── Application ───────────────────────────────────────────
APP_NAME=Salamatian
APP_ENV=production
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=Passwork
BASE_URL=http://localhost:8001
HOST_IP=0.0.0.0
HOST_PORT=8001
WORKER_COUNT=8

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=salamatian
POSTGRES_EXPOSED_PORT=8003
POSTGRES_PASSWORD=Passwork
POSTGRES_DB=salamatian
DATABASE_URL=postgresql+asyncpg://salamatian:Passwork@postgres:8003/salamatian

# ─── Redis ─────────────────────────────────────────────────
REDIS_EXPOSED_PORT=8002
REDIS_PASSWORD=Passwork
REDIS_URL=redis://:Passwork@redis:8002/0

# ─── Celery ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:8002/1
CELERY_RESULT_BACKEND=redis://redis:8002/2

# ─── JWT ───────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# ─── Storage ───────────────────────────────────────────────
STORAGE_ROOT=/app/storage/uploads
EXCEL_INBOX_DIR=/app/storage/uploads/excel/inbox
MAX_IMAGE_SIZE_MB=5
MAX_LEAD_IMAGES=10

# ─── Rate limiting ─────────────────────────────────────────
PUBLIC_LEAD_RATE_PER_HOUR=10

# ─── Admin bootstrap ───────────────────────────────────────
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@salamatian.local
BOOTSTRAP_ADMIN_PASSWORD=Passwork

# ─── Optional notification channels ────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@salamatian.local
